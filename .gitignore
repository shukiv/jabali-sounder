# Binaries
bin/
/server
/desktop
*.exe
*.dll
*.so
*.dylib

# Go/TS build info
*.tsbuildinfo

# Test + coverage
coverage.out
coverage.html
*.test
*.prof

# Go workspaces
go.work
go.work.sum

# Frontend build output — everything in dist/ is generated by
# `npm run build` EXCEPT the .gitkeep sentinel which keeps the directory
# present on fresh clones so //go:embed succeeds before anyone has run the build.
manager-ui/dist/*
!manager-ui/dist/.gitkeep
manager-ui/node_modules/
manager-ui/.vite/

# Secrets / local config — NEVER commit
.env
.env.local
.env.*.local
config.local.toml

# Editor / OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# direnv project-scoped env (DB creds etc.)
.envrc
.direvf/

# Build artifacts
dist/

# Manager secret key — NEVER commit
*.key
secrets.key
.gotmp/

# Android build outputs (Wails v3 mobile) — generated, not source
build/android/app/build/
build/android/.gradle/
build/android/app/src/main/jniLibs/
build/android/local.properties
*.apk
*.aab
build/android/build/
