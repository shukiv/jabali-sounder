# Jabali Manager — example environment.
#
# Copy to .env for local dev. NEVER commit a real secrets file.

# Server
JABALI_MANAGER_ADDR=127.0.0.1:8484
JABALI_MANAGER_ENV=development

# Logging
LOG_LEVEL=info
LOG_FORMAT=text

# Database (MariaDB)
# JABALI_MANAGER_DATABASE_URL=jabali_manager:CHANGE_ME@tcp(127.0.0.1:3306)/jabali_manager?parseTime=true&charset=utf8mb4&loc=UTC

# Secret key file (32 bytes for AES-256-GCM)
# Generate: openssl rand -out secrets.key 32
# JABALI_MANAGER_SECRET_KEY_FILE=./secrets.key
